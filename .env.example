# Copy this file to .env and fill in real values
# cp .env.example .env

# Better Stack (logging)
BETTER_STACK_SOURCE_TOKEN=your_token_here

# LLM Providers (at least one required; tried in order: Google → Groq → OpenAI → Ollama)

# ── Google AI Studio — Gemma 4 (PRIMARY, recommended) ─────────────────────────
# Get free key at: https://aistudio.google.com/apikey
LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_AI_MODEL=gemma-4-27b-it
# Smaller/faster variant: gemma-4-9b-it

# ── Groq fallback (fast, free tier — https://console.groq.com) ────────────────
LLM_API_KEY=

# ── OpenAI fallback (optional — https://platform.openai.com) ──────────────────
OPENAI_API_KEY=

# ── Ollama local fallback (optional — run: ollama serve) ──────────────────────
OLLAMA_BASE_URL=

# Models (used when GOOGLE_AI_MODEL is not set)
LLM_ANALYZER_MODEL=gemma-4-27b-it
LLM_REPORT_MODEL=gemma-4-27b-it

# Thresholds
AI_SUSPICIOUS_THRESHOLD=60
SEND_ALL_TO_BETTERSTACK=true

# API
API_PORT=9000
API_HOST=0.0.0.0

# Security — REQUIRED in production, leave empty only for local dev
MY_API_TOKEN=
CORS_ORIGINS=http://localhost:3000,http://localhost:9000
RATE_LIMIT_PER_MINUTE=60

# Environment
ENVIRONMENT=development

# Database (SQLite default for dev, PostgreSQL for prod via docker-compose)
# SQLite:     sqlite+aiosqlite:///./ir_agent.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/ir_agent
DATABASE_URL=sqlite+aiosqlite:///./ir_agent.db

# PostgreSQL password (used by docker-compose postgres service)
POSTGRES_PASSWORD=changeme_in_production

# Threat Intelligence APIs
# VirusTotal (free tier: 4 req/min, 500 req/day)
# Get key at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB (free tier: 1000 req/day)
# Get key at: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# IoC lookup cache TTL in seconds (default: 3600 = 1 hour)
IOC_CACHE_TTL_SECONDS=3600
# IoC cache max entries before LRU eviction (default: 10000)
IOC_CACHE_MAX_SIZE=10000

# Agent memory: max concurrent sessions kept in RAM (LRU eviction, default: 1000)
AGENT_SESSION_MAX_SIZE=1000
# Agent memory: session inactivity TTL in seconds (default: 3600 = 1 hour)
AGENT_SESSION_TTL_SECONDS=3600

# Agent: max wall-clock seconds for a single arun() call before 504 timeout (default: 120)
AGENT_TIMEOUT_SECONDS=120

# Redis (optional — enables distributed rate limiting for multi-instance deployments)
# Without this, rate limiting works in-memory per-instance only
# REDIS_URL=redis://localhost:6379/0
