# Copy this file to .env and fill in real values
# cp .env.example .env

# Better Stack (logging)
BETTER_STACK_SOURCE_TOKEN=your_token_here

# LLM Providers (at least one required; tried in order: Groq → OpenAI → Ollama)

# Groq (fast, free tier — https://console.groq.com)
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here

# OpenAI fallback (optional — https://platform.openai.com)
OPENAI_API_KEY=

# Ollama local fallback (optional — run: ollama serve)
OLLAMA_BASE_URL=

# Models
LLM_ANALYZER_MODEL=llama-3.3-70b-versatile
LLM_REPORT_MODEL=llama-3.3-70b-versatile

# Thresholds
AI_SUSPICIOUS_THRESHOLD=60
SEND_ALL_TO_BETTERSTACK=true

# API
API_PORT=9000
API_HOST=0.0.0.0

# Security (leave empty to disable auth — NOT recommended for production)
MY_API_TOKEN=
CORS_ORIGINS=http://localhost:3000,http://localhost:9000
RATE_LIMIT_PER_MINUTE=60

# Environment
ENVIRONMENT=development

# Database (SQLite default for dev, PostgreSQL for prod)
# SQLite:     sqlite+aiosqlite:///./ir_agent.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/ir_agent
DATABASE_URL=sqlite+aiosqlite:///./ir_agent.db

# Threat Intelligence APIs
# VirusTotal (free tier: 4 req/min, 500 req/day)
# Get key at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB (free tier: 1000 req/day)
# Get key at: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# IoC lookup cache TTL in seconds (default: 3600 = 1 hour)
IOC_CACHE_TTL_SECONDS=3600

# Redis (optional — enables distributed rate limiting for multi-instance deployments)
# Without this, rate limiting works in-memory per-instance only
# REDIS_URL=redis://localhost:6379/0
